{
  "name": "somb",
  "author": {
    "name": "Vincent Martens",
    "url": "https://vmartens.de"
  },
  "scripts": {
    "prepare": "husky",
    "dev": "cd app && nue",
    "build": "cd app && rm -rf .dist && nue build",
    "preview": "cd app && nue preview",
    "build:infra": "bun run build --cwd infra",
    "test:infra": "cd infra && bunx jest",
    "new-post": "bun scripts/new-post.ts",
    "new-blog": "bun scripts/new-post.ts",
    "publish-post": "bun scripts/publish-post.ts"
  },
  "workspaces": [
    "infra/"
  ],
  "dependencies": {
    "nuekit": "2.0.0-beta.2"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.2.1",
    "@commitlint/config-conventional": "^21.2.0",
    "husky": "^9.1.7",
    "standard-version": "^9.5.0"
  }
}